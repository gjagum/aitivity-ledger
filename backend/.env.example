# PostgreSQL connection string. URL-encode any special chars in the password.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aitivity-ledger

# Shared secret required for tenant-management routes (create/list/delete).
# The frontend sends this as `Authorization: Bearer <token>` in admin mode.
# Generate one with: openssl rand -hex 32
ADMIN_TOKEN=dev-admin-token-change-me
